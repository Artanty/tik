{
    "event_bus_hooks": [
        {
            "on": {
                "event": "AUTH_DONE"
            },
             "waitFor": {
                "event": "PRODUCT_BTN_READY",
                "conditions": {
                    "projectId": "tik"
                }
            },
            "push": {
                "type": "TRIGGER_ACTION",
                "action": "INIT_TIK_STREAM",
                "payload": {
                    "project_id": "tik"               
                }
            },
            "lives": "once"
        },
        {
            "on": {
                "event": "ASK_BACK_URLS"
            },
            "push": {
                "type": "ANSWER",
                "payload": {
                    "project_id": "tik",
                    "back_url": "http://localhost:3202"
                }
            },
            "lives": 1
        }
    ],
    "interceptors": [
        {
            "on": "REQUEST",
            "url_pattern": "/^http:\/\/localhost:3202\/(sse1|collectEventsState)(\/.*)?$/",
            "data": [
                {
                    "target": "headers",
                    "key": "Authorization",
                    "valueHandler": {
                        "source": "localStorage",
                        "prop": "accessToken",
                        "prepend": "Bearer "
                    } 
                },
                {
                    "target": "headers",
                    "key": "X-Web-Host-URL",
                    "valueHandler": {
                        "source": "window",
                        "prop": "location.origin"
                    } 
                }
            ]
        }
    ]
}
